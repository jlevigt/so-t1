<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.Controller">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lblCestoStatus" text="Cesto não iniciado" style="-fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnIniciar" disable="true" onAction="#iniciarSimulacao" text="Começar Simulação" />
    </HBox>

    <TableView fx:id="tableCriancas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colTb" prefWidth="100.0" text="Tb (ms)" />
            <TableColumn fx:id="colTd" prefWidth="100.0" text="Td (ms)" />
            <TableColumn fx:id="colTemBola" prefWidth="100.0" text="Com Bola?" />
            <TableColumn fx:id="colEstado" prefWidth="200.0" text="Estado" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Tb (ms):" />
        <TextField fx:id="inputTb" prefWidth="60.0" text="1000" />
        <Label text="Td (ms):" />
        <TextField fx:id="inputTd" prefWidth="60.0" text="1000" />
        <CheckBox fx:id="checkTemBola" text="Começa com Bola?" selected="true" />
        <Button fx:id="btnCriarCrianca" onAction="#criarCrianca" text="Criar Criança" />
    </HBox>

    <TextArea fx:id="txtLog" editable="false" prefHeight="150.0" />
</VBox>
